# Copy to .env and fill in real values. .env is gitignored.

# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://ahody:ahody@localhost:5432/ahody

# API key required on every request once auth is enabled (PR 8).
# Any non-empty string; clients send `Authorization: Bearer <API_KEY>`.
API_KEY=change-me

# Voyage AI for embeddings (https://www.voyageai.com)
VOYAGE_API_KEY=

# Anthropic for /chat (https://console.anthropic.com)
ANTHROPIC_API_KEY=
