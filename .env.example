# Postgres connection — defaults to the docker-compose service.
DATABASE_URL=postgresql://ahody:ahody@localhost:5432/ahody

# Upstream API keys. Both are required for the full pipeline:
# VOYAGE_API_KEY for embeddings + reranking, ANTHROPIC_API_KEY for /chat.
VOYAGE_API_KEY=
ANTHROPIC_API_KEY=

# Embedding model alias (DECISIONS.md §2). Override only if migrating.
EMBEDDING_MODEL=voyage-4

# Knowledge-graph models (DECISIONS.md §KG). Haiku for per-chunk extraction,
# Sonnet for per-document-per-type alias resolution. Override only if testing
# alternatives.
EXTRACTION_MODEL=claude-haiku-4-5
RESOLUTION_MODEL=claude-sonnet-4-6
